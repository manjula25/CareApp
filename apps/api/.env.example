# ── Database ──────────────────────────────────────────────
# Path to the SQLite database file (default: apps/api/data/caresync.sqlite)
# DB_PATH=./data/caresync.sqlite

# ── API Server ────────────────────────────────────────────
# Port the Express API listens on (default: 4000)
# PORT=4000

# ── FHIR ──────────────────────────────────────────────────
# HAPI FHIR server base URL (default: http://localhost:8080/fhir)
# FHIR_BASE_URL=http://localhost:8080/fhir

# ── SMART on FHIR ─────────────────────────────────────────
# SMART token endpoint (default: http://localhost:${PORT}/smart/token)
# In production, point this at the Keycloak token endpoint instead:
# SMART_TOKEN_ENDPOINT=http://localhost:4000/smart/token

# ── SMART on FHIR (Production — Open Question 8) ──────────
# When SMART_JWKS_URL is set, the smartAuth middleware switches from HS256
# (in-process token server) to RS256 (Keycloak JWKS). The token server is
# still mounted for POC backward compat — production deployments point
# SMART_TOKEN_ENDPOINT at Keycloak instead.
# SMART_JWKS_URL=https://localhost:8443/realms/caresync/protocol/openid-connect/certs
# SMART_ISSUER=https://localhost:8443/realms/caresync
# SMART_AUDIENCE=http://localhost:8080/fhir
# SMART_SERVER_SECRET=caresync-dev-authz-server-secret-do-not-use-in-production

# ── Real-time (S6) ────────────────────────────────────────
# URL the HAPI container calls on Task changes — must be reachable FROM the
# container, not just the host (default: host.docker.internal, Docker
# Desktop's route back to the host).
# SUBSCRIPTION_CALLBACK_URL=http://host.docker.internal:4000/api/fhir/subscription-hook

# ── Auth / JWT ────────────────────────────────────────────
# Secret used to sign JWT tokens (default: caresync-dev-secret-do-not-use-in-production)
# JWT_SECRET=caresync-dev-secret-do-not-use-in-production

# ── OpenAI (agent analysis) ────────────────────────────────
# API key for OpenAI gpt-5.5 agent runs. Unset disables live analysis.
OPENAI_API_KEY=
