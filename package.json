{
  "name": "caresync-ai",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace apps/api & npm run dev --workspace apps/web",
    "build": "npm run build --workspace apps/api && npm run build --workspace apps/web",
    "lint": "npm run lint --workspace apps/api && npm run lint --workspace apps/web",
    "test:api": "npm run test --workspace apps/api",
    "test:web": "npm run test --workspace apps/web",
    "test:e2e": "npm run test:e2e --workspace apps/web",
    "fhir:up": "docker compose up -d hapi-fhir",
    "fhir:import": "npm run import --workspace apps/api",
    "eval": "npm run eval --workspace apps/api",
    "review:render": "npm run review:render --workspace apps/api",
    "migrate": "npm run migrate --workspace apps/api",
    "seed": "npm run seed --workspace apps/api"
  }
}
